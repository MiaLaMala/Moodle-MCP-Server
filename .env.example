# Moodle MCP Server configuration
# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# Required: base URL of your Moodle instance (no trailing slash).
# Example: https://lms.lernen.hamburg
MOODLE_URL=

# Auth option A — username + password (server exchanges them for a token via /login/token.php).
MOODLE_USERNAME=
MOODLE_PASSWORD=

# Auth option B — a pre-issued Moodle Web Services token.
# If MOODLE_TOKEN is set, username/password are ignored.
MOODLE_TOKEN=

# Optional: where to persist the exchanged token so it is reused across server starts.
# Defaults to ~/.cache/moodle-mcp/token.json
# MOODLE_TOKEN_CACHE=

# Optional: request timeout in seconds (default 30).
# MOODLE_TIMEOUT=30
